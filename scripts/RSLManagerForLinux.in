#!/bin/sh
APP_DIR="@APP_DIR@"
PYTHON="@PYTHON@"
LOG_DIR="@LOG_DIR@"
LOG_FILE="@LOG_FILE@"
PID_FILE="@PID_FILE@"
WM_CLASS="@WM_CLASS@"
APP_TITLE="@APP_TITLE@"
LOG_MAX_LINES=60000

mkdir -p "$LOG_DIR"

trim_log() {
    [ -f "$LOG_FILE" ] || return 0

    line_count=$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    [ "$line_count" -gt "$LOG_MAX_LINES" ] 2>/dev/null || return 0

    keep_lines=$((LOG_MAX_LINES - 1))
    trimmed_count=$((line_count - keep_lines))
    tmp_file="$LOG_FILE.tmp.$$"

    if tail -n "$keep_lines" "$LOG_FILE" > "$tmp_file" 2>/dev/null; then
        {
            printf '%s Log trimmed: removed %s older lines; kept newest %s lines\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$trimmed_count" "$keep_lines"
            cat "$tmp_file"
        } > "$LOG_FILE"
    fi

    rm -f "$tmp_file"
}

log() {
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

log_stream() {
    while IFS= read -r line; do
        log "$1: $line"
    done
}

focus_existing() {
    if wmctrl -xa "$WM_CLASS" >> "$LOG_FILE" 2>&1 || wmctrl -a "$APP_TITLE" >> "$LOG_FILE" 2>&1; then
        log "Focused existing app window"
        return 0
    fi

    log "Failed to focus existing app window with wmctrl"
    return 1
}

trim_log
log "Launch requested: $0 $*"

existing_pid=""
if [ -r "$PID_FILE" ]; then
    existing_pid=$(cat "$PID_FILE")
    if ! kill -0 "$existing_pid" >/dev/null 2>&1; then
        log "Removing stale PID file for PID $existing_pid"
        rm -f "$PID_FILE"
        existing_pid=""
    fi
fi

if [ -z "$existing_pid" ]; then
    existing_pid=$(pgrep -f "python.*gui.py" | grep -v "^$$" | head -n 1 || true)
fi

if [ -n "$existing_pid" ]; then
    log "Existing app process detected: PID $existing_pid"
    focus_existing
    exit 0
fi

cd "$APP_DIR" || {
    log "Failed to cd into $APP_DIR"
    exit 1
}

echo "$$" > "$PID_FILE"
trap 'rm -f "$PID_FILE"' EXIT INT TERM

log "Starting app with $PYTHON"
fifo_file="$LOG_DIR/$(basename "$PID_FILE").fifo.$$"
if mkfifo "$fifo_file" 2>/dev/null; then
    log_stream "App" < "$fifo_file" &
    logger_pid=$!
    "$PYTHON" gui.py "$@" > "$fifo_file" 2>&1
    status=$?
    wait "$logger_pid" 2>/dev/null || true
    rm -f "$fifo_file"
else
    log "Failed to create log fifo; app output will be appended without per-line timestamps"
    "$PYTHON" gui.py "$@" >> "$LOG_FILE" 2>&1
    status=$?
fi
log "App exited with status $status"
trim_log
exit "$status"
